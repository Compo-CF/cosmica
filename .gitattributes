# Force LF line endings for cross-platform iOS work
*.swift          text eol=lf
*.yml            text eol=lf
*.yaml           text eol=lf
*.json           text eol=lf
*.md             text eol=lf
*.plist          text eol=lf
*.entitlements   text eol=lf
*.xcconfig       text eol=lf
*.gitignore      text eol=lf
*.gitattributes  text eol=lf
*.sh             text eol=lf

# Binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.pdf   binary
*.ico   binary
*.zip   binary
